    "bg": "#FAFAFA",
    "bg_alt": "#F2F2F2",
    "fg": "#0A0A0A",
    "fg_alt": "#4A4A4A",

    "border": "#E8E8E8",
    "border_variant": "#F2F2F2",
    "element_hover": "#EBEBEB",
    "disabled": "#7A7A7A",

    "gray1": "#F2F2F2",
