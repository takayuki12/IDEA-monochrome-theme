    "gray6": "#5A5A5A",
    "gray7": "#3A3A3A",
    "gray8": "#0A0A0A",

    "error": "#d20f39",
    "warning": "#df8e1d",
    "info": "#179299",
    "success": "#40a02b",
    "conflict": "#fe640b",

    "vcs_added": "#40a02b",
